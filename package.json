{
  "name": "municipal-corp-property-management-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build && tsc -p tsconfig.server.json",
    "ci": "prisma generate && npm run build && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.json --noEmit",
    "start": "node dist/server/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed/full-demo.ts",
    "db:seed:legacy": "tsx prisma/seed/seed.ts && tsx prisma/seed/demo-data.ts && tsx prisma/seed/add-citizen-passwords.ts",
    "db:seed:prod": "tsx prisma/seed/deploy.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jose": "^5.9.6",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}

# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth
AUTH_SECRET=your-jwt-secret-min-32-characters

# Supabase Storage (media uploads) — from Project Settings → API
# Use the service_role key on the server only; never expose it in the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_STORAGE_BUCKET=municipal-pms
SUPABASE_MAX_UPLOAD_BYTES=10485760

# Optional: Supabase personal access token (sbp_...) for CLI/Management API only
# SUPABASE_ACCESS_TOKEN=
